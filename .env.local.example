# Copy this file to .env.local and fill in your Supabase project's values
# (Project Settings -> API in the Supabase dashboard). Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only, bypasses RLS. Reserved for Phase 3 admin
# tooling; not used by any code yet, but wire it up now for convenience.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (resend.com) — sends the booking confirmation email.
# RESEND_FROM_EMAIL can stay as the sandbox sender until you verify your own domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=LUMA <onboarding@resend.dev>

# Optional — if set, an internal notification email is sent here every time
# a guest completes a booking. Leave blank to skip it entirely.
ADMIN_NOTIFICATION_EMAIL=

# Your production URL (no trailing slash) — used for the sitemap, robots.txt,
# canonical links, and Open Graph URLs. Falls back to localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=
