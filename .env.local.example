# Copy this file to .env.local and fill in your Supabase project's values
# (Project Settings -> API in the Supabase dashboard). Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only, bypasses RLS. Reserved for Phase 3 admin
# tooling; not used by any code yet, but wire it up now for convenience.
SUPABASE_SERVICE_ROLE_KEY=
